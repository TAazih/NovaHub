-- Nova UI Library V2 (Premium MacOS Edition)
local Nova = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

--[EXECUTOR PROTECTION]
local function GetSafeParent()
    if gethui then return gethui() end
    local success, coreGui = pcall(function() return CoreGui end)
    if success and coreGui then return coreGui end
    return Players.LocalPlayer:WaitForChild("PlayerGui")
end

local SafeParent = GetSafeParent()

-- Clean up old instances
for _, child in ipairs(SafeParent:GetChildren()) do
    if child.Name == "NovaUI_Hub" then child:Destroy() end
end

-- ScreenGui Setup
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "NovaUI_Hub"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = SafeParent

-- Global Notification System
local NotifContainer = Instance.new("Frame")
NotifContainer.Name = "NotifContainer"
NotifContainer.Size = UDim2.new(0, 250, 1, -20)
NotifContainer.Position = UDim2.new(1, -270, 0, 20)
NotifContainer.BackgroundTransparency = 1
NotifContainer.Parent = ScreenGui

local NotifLayout = Instance.new("UIListLayout")
NotifLayout.SortOrder = Enum.SortOrder.LayoutOrder
NotifLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
NotifLayout.Padding = UDim.new(0, 10)
NotifLayout.Parent = NotifContainer

function Nova:MakeNotification(options)
    local title = options.Name or "Notification"
    local content = options.Content or ""
    local time = options.Time or 5

    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(1, 0, 0, 60)
    notifFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    notifFrame.BackgroundTransparency = 1
    notifFrame.Position = UDim2.new(1, 50, 0, 0)
    Instance.new("UICorner", notifFrame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", notifFrame).Color = Color3.fromRGB(60, 60, 60)
    notifFrame.Parent = NotifContainer

    local titleLbl = Instance.new("TextLabel", notifFrame)
    titleLbl.Size = UDim2.new(1, -20, 0, 20)
    titleLbl.Position = UDim2.new(0, 10, 0, 5)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Color3.fromRGB(0, 170, 255)
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 14
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTransparency = 1

    local descLbl = Instance.new("TextLabel", notifFrame)
    descLbl.Size = UDim2.new(1, -20, 0, 30)
    descLbl.Position = UDim2.new(0, 10, 0, 25)
    descLbl.BackgroundTransparency = 1
    descLbl.Text = content
    descLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    descLbl.Font = Enum.Font.Gotham
    descLbl.TextSize = 12
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.TextWrapped = true
    descLbl.TextTransparency = 1

    TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0}):Play()
    TweenService:Create(titleLbl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    TweenService:Create(descLbl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()

    task.spawn(function()
        task.wait(time)
        TweenService:Create(titleLbl, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(descLbl, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        local fadeOut = TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(1, 50, 0, 0), BackgroundTransparency = 1})
        fadeOut:Play()
        fadeOut.Completed:Wait()
        notifFrame:Destroy()
    end)
end

function Nova:MakeWindow(options)
    local WindowTitle = options.Title or "Nova UI Hub"
    
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 550, 0, 350)
    MainFrame.Position = UDim2.new(0.5, -275, 0.5, -175)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    MainFrame.ClipsDescendants = true -- Required for smooth minimization
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(45, 45, 45)

    -- [ANIMATION] Intro Pop-In
    local uiScale = Instance.new("UIScale", MainFrame)
    uiScale.Scale = 0.8
    TweenService:Create(uiScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()

    -- TopBar Setup
    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    TopBar.BorderSizePixel = 0
    Instance.new("UICorner", TopBar).CornerRadius = UDim.new(0, 8)
    
    -- Fix Bottom Corners of TopBar clipping
    local TopBarHider = Instance.new("Frame", TopBar)
    TopBarHider.Size = UDim2.new(1, 0, 0, 5)
    TopBarHider.Position = UDim2.new(0, 0, 1, -5)
    TopBarHider.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    TopBarHider.BorderSizePixel = 0

    local TitleLabel = Instance.new("TextLabel", TopBar)
    TitleLabel.Size = UDim2.new(1, -100, 1, 0)
    TitleLabel.Position = UDim2.new(0, 70, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = WindowTitle
    TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 13
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- [MACOS CONTROLS]
    local MacControls = Instance.new("Frame", TopBar)
    MacControls.Size = UDim2.new(0, 60, 1, 0)
    MacControls.Position = UDim2.new(0, 10, 0, 0)
    MacControls.BackgroundTransparency = 1

    local function CreateMacButton(name, color, posOffset, hoverColor)
        local btn = Instance.new("TextButton", MacControls)
        btn.Name = name
        btn.Size = UDim2.new(0, 12, 0, 12)
        btn.Position = UDim2.new(0, posOffset, 0.5, -6)
        btn.BackgroundColor3 = color
        btn.Text = ""
        btn.AutoButtonColor = false
        Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
        
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = hoverColor}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color}):Play()
        end)
        return btn
    end

    local CloseBtn = CreateMacButton("Close", Color3.fromRGB(255, 95, 86), 0, Color3.fromRGB(255, 130, 120))
    local MinBtn = CreateMacButton("Minimize", Color3.fromRGB(255, 189, 46), 20, Color3.fromRGB(255, 210, 90))
    local MaxBtn = CreateMacButton("Maximize", Color3.fromRGB(39, 201, 63), 40, Color3.fromRGB(80, 220, 100))

    -- Close Logic
    CloseBtn.MouseButton1Click:Connect(function()
        local tween = TweenService:Create(uiScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0})
        tween:Play()
        tween.Completed:Wait()
        ScreenGui:Destroy()
    end)

    -- Minimize Logic
    local minimized = false
    MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = UDim2.new(0, 550, 0, 35)}):Play()
        else
            TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = UDim2.new(0, 550, 0, 350)}):Play()
        end
    end)

    -- Smooth Dragging
    local dragging, dragInput, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Sidebar & Content
    local Sidebar = Instance.new("ScrollingFrame", MainFrame)
    Sidebar.Size = UDim2.new(0, 140, 1, -45)
    Sidebar.Position = UDim2.new(0, 10, 0, 40)
    Sidebar.BackgroundTransparency = 1
    Sidebar.ScrollBarThickness = 0
    local SidebarLayout = Instance.new("UIListLayout", Sidebar)
    SidebarLayout.Padding = UDim.new(0, 5)

    local ContentContainer = Instance.new("Frame", MainFrame)
    ContentContainer.Size = UDim2.new(1, -165, 1, -45)
    ContentContainer.Position = UDim2.new(0, 155, 0, 40)
    ContentContainer.BackgroundTransparency = 1

    local Window = {}
    local Tabs = {}

    function Window:MakeTab(options)
        local TabName = options.Name or "Tab"
        local TabIcon = options.Icon
        
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(1, 0, 0, 32)
        TabBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        TabBtn.Text = ""
        TabBtn.AutoButtonColor = false
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local IconLabel, TextLbl
        if TabIcon then
            IconLabel = Instance.new("ImageLabel", TabBtn)
            IconLabel.Size = UDim2.new(0, 16, 0, 16)
            IconLabel.Position = UDim2.new(0, 10, 0.5, -8)
            IconLabel.BackgroundTransparency = 1
            IconLabel.Image = TabIcon
            IconLabel.ImageColor3 = Color3.fromRGB(150, 150, 150)
            
            TextLbl = Instance.new("TextLabel", TabBtn)
            TextLbl.Position = UDim2.new(0, 35, 0, 0)
            TextLbl.Size = UDim2.new(1, -35, 1, 0)
        else
            TextLbl = Instance.new("TextLabel", TabBtn)
            TextLbl.Position = UDim2.new(0, 10, 0, 0)
            TextLbl.Size = UDim2.new(1, -10, 1, 0)
        end

        TextLbl.BackgroundTransparency = 1
        TextLbl.Text = TabName
        TextLbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        TextLbl.Font = Enum.Font.GothamSemibold
        TextLbl.TextSize = 13
        TextLbl.TextXAlignment = Enum.TextXAlignment.Left

        local TabContent = Instance.new("ScrollingFrame", ContentContainer)
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 2
        TabContent.Visible = false
        local ContentLayout = Instance.new("UIListLayout", TabContent)
        ContentLayout.Padding = UDim.new(0, 8)

        table.insert(Tabs, {Btn = TabBtn, Text = TextLbl, Icon = IconLabel, Content = TabContent})

        TabBtn.MouseButton1Click:Connect(function()
            for _, t in pairs(Tabs) do
                TweenService:Create(t.Btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
                TweenService:Create(t.Text, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
                if t.Icon then TweenService:Create(t.Icon, TweenInfo.new(0.3), {ImageColor3 = Color3.fromRGB(150, 150, 150)}):Play() end
                t.Content.Visible = false
            end
            
            TweenService:Create(TabBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(35, 35, 35)}):Play()
            TweenService:Create(TextLbl, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            if IconLabel then TweenService:Create(IconLabel, TweenInfo.new(0.3), {ImageColor3 = Color3.fromRGB(0, 170, 255)}):Play() end
            
            -- Fade in content
            TabContent.Visible = true
            TabContent.CanvasPosition = Vector2.new(0,0)
        end)

        if #Tabs == 1 then
            TabBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            TextLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            if IconLabel then IconLabel.ImageColor3 = Color3.fromRGB(0, 170, 255) end
            TabContent.Visible = true
        end

        local Elements = {}

        -- [NEW FEATURE] Labels
        function Elements:AddLabel(opts)
            local Lbl = Instance.new("TextLabel", TabContent)
            Lbl.Size = UDim2.new(1, -10, 0, 25)
            Lbl.BackgroundTransparency = 1
            Lbl.Text = opts.Text or "Label"
            Lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            Lbl.Font = Enum.Font.GothamMedium
            Lbl.TextSize = 13
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
        end

        function Elements:AddButton(opts)
            local Btn = Instance.new("TextButton", TabContent)
            Btn.Size = UDim2.new(1, -10, 0, 36)
            Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Btn.Text = ""
            Btn.AutoButtonColor = false
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", Btn).Color = Color3.fromRGB(45, 45, 45)

            local titleOff = 15
            if opts.Icon then
                local Ico = Instance.new("ImageLabel", Btn)
                Ico.Size = UDim2.new(0, 16, 0, 16)
                Ico.Position = UDim2.new(0, 15, 0.5, -8)
                Ico.BackgroundTransparency = 1
                Ico.Image = opts.Icon
                Ico.ImageColor3 = Color3.fromRGB(220, 220, 220)
                titleOff = 40
            end

            local Title = Instance.new("TextLabel", Btn)
            Title.Size = UDim2.new(1, -titleOff, 1, 0)
            Title.Position = UDim2.new(0, titleOff, 0, 0)
            Title.BackgroundTransparency = 1
            Title.Text = opts.Name or "Button"
            Title.TextColor3 = Color3.fromRGB(220, 220, 220)
            Title.Font = Enum.Font.GothamSemibold
            Title.TextSize = 13
            Title.TextXAlignment = Enum.TextXAlignment.Left

            Btn.MouseEnter:Connect(function() TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}):Play() end)
            Btn.MouseLeave:Connect(function() TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play() end)
            Btn.MouseButton1Click:Connect(function()
                TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
                task.wait(0.1)
                TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}):Play()
                if opts.Callback then opts.Callback() end
            end)
        end

        function Elements:AddToggle(opts)
            local Tog = Instance.new("TextButton", TabContent)
            Tog.Size = UDim2.new(1, -10, 0, 36)
            Tog.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Tog.Text = "   " .. (opts.Name or "Toggle")
            Tog.TextColor3 = Color3.fromRGB(220, 220, 220)
            Tog.Font = Enum.Font.GothamSemibold
            Tog.TextSize = 13
            Tog.TextXAlignment = Enum.TextXAlignment.Left
            Tog.AutoButtonColor = false
            Instance.new("UICorner", Tog).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", Tog).Color = Color3.fromRGB(45, 45, 45)

            local IndicatorBg = Instance.new("Frame", Tog)
            IndicatorBg.Size = UDim2.new(0, 36, 0, 18)
            IndicatorBg.Position = UDim2.new(1, -46, 0.5, -9)
            IndicatorBg.BackgroundColor3 = opts.Default and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 40)
            Instance.new("UICorner", IndicatorBg).CornerRadius = UDim.new(1, 0)

            local Circle = Instance.new("Frame", IndicatorBg)
            Circle.Size = UDim2.new(0, 14, 0, 14)
            Circle.Position = opts.Default and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            local state = opts.Default or false

            Tog.MouseEnter:Connect(function() TweenService:Create(Tog, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}):Play() end)
            Tog.MouseLeave:Connect(function() TweenService:Create(Tog, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play() end)

            Tog.MouseButton1Click:Connect(function()
                state = not state
                local targetPos = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
                local targetColor = state and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 40)
                
                TweenService:Create(Circle, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetPos}):Play()
                TweenService:Create(IndicatorBg, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
                if opts.Callback then opts.Callback(state) end
            end)
        end

        function Elements:AddSlider(opts)
            local min, max, default = opts.Min or 0, opts.Max or 100, opts.Default or opts.Min or 0
            local inc = opts.Increment or 1

            local SliderBg = Instance.new("Frame", TabContent)
            SliderBg.Size = UDim2.new(1, -10, 0, 50)
            SliderBg.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", SliderBg).Color = Color3.fromRGB(45, 45, 45)

            local Label = Instance.new("TextLabel", SliderBg)
            Label.Size = UDim2.new(1, -20, 0, 20)
            Label.Position = UDim2.new(0, 15, 0, 6)
            Label.BackgroundTransparency = 1
            Label.Text = opts.Name or "Slider"
            Label.TextColor3 = Color3.fromRGB(220, 220, 220)
            Label.Font = Enum.Font.GothamSemibold
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local ValLabel = Instance.new("TextLabel", SliderBg)
            ValLabel.Size = UDim2.new(0, 50, 0, 20)
            ValLabel.Position = UDim2.new(1, -65, 0, 6)
            ValLabel.BackgroundTransparency = 1
            ValLabel.Text = tostring(default)
            ValLabel.TextColor3 = Color3.fromRGB(0, 170, 255)
            ValLabel.Font = Enum.Font.GothamBold
            ValLabel.TextSize = 13
            ValLabel.TextXAlignment = Enum.TextXAlignment.Right

            local Track = Instance.new("Frame", SliderBg)
            Track.Size = UDim2.new(1, -30, 0, 4)
            Track.Position = UDim2.new(0, 15, 0, 34)
            Track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame", Track)
            Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local dragging = false
            local function updateSlider(input)
                local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local val = min + ((max - min) * pos)
                val = math.floor(val / inc + 0.5) * inc
                
                TweenService:Create(Fill, TweenInfo.new(0.15), {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}):Play()
                ValLabel.Text = tostring(val)
                if opts.Callback then opts.Callback(val) end
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    updateSlider(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
            end)
        end

        -- [NEW FEATURE] Keybinds
        function Elements:AddKeybind(opts)
            local currentKey = opts.Key or Enum.KeyCode.E
            local binding = false

            local BindBtn = Instance.new("TextButton", TabContent)
            BindBtn.Size = UDim2.new(1, -10, 0, 36)
            BindBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            BindBtn.Text = "   " .. (opts.Name or "Keybind")
            BindBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
            BindBtn.Font = Enum.Font.GothamSemibold
            BindBtn.TextSize = 13
            BindBtn.TextXAlignment = Enum.TextXAlignment.Left
            BindBtn.AutoButtonColor = false
            Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", BindBtn).Color = Color3.fromRGB(45, 45, 45)

            local KeyLabel = Instance.new("TextLabel", BindBtn)
            KeyLabel.Size = UDim2.new(0, 60, 0, 22)
            KeyLabel.Position = UDim2.new(1, -70, 0.5, -11)
            KeyLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            KeyLabel.Text = currentKey.Name
            KeyLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            KeyLabel.Font = Enum.Font.GothamBold
            KeyLabel.TextSize = 12
            Instance.new("UICorner", KeyLabel).CornerRadius = UDim.new(0, 4)

            BindBtn.MouseEnter:Connect(function() TweenService:Create(BindBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}):Play() end)
            BindBtn.MouseLeave:Connect(function() TweenService:Create(BindBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play() end)

            BindBtn.MouseButton1Click:Connect(function()
                binding = true
                KeyLabel.Text = "..."
                TweenService:Create(KeyLabel, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 170, 255)}):Play()
            end)

            UserInputService.InputBegan:Connect(function(input)
                if binding and input.UserInputType == Enum.UserInputType.Keyboard then
                    currentKey = input.KeyCode
                    KeyLabel.Text = currentKey.Name
                    TweenService:Create(KeyLabel, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
                    binding = false
                    if opts.Callback then opts.Callback(currentKey) end
                elseif not binding and input.KeyCode == currentKey then
                    if opts.Callback then opts.Callback(currentKey) end
                end
            end)
        end

        return Elements
    end

    return Window
end

return Nova
