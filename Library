                        currentKey = input.KeyCode
                        BindBtn.Text = currentKey.Name
                        TweenService:Create(BindBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 35), TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
                        binding = false
                        ConfigData[opts.Name.."_Keybind"] = currentKey.Name
                        SaveConfig()
                    elseif not binding and input.KeyCode == currentKey then
                        UpdateState(not state)
                    end
                end)
            end

            if state and opts.Callback then opts.Callback(state) end
        end

        function Elements:AddSlider(opts)
            local min, max = opts.Min or 0, opts.Max or 100
            local default = ConfigData[opts.Name] ~= nil and ConfigData[opts.Name] or (opts.Default or min)
            local inc = opts.Increment or 1

            local SliderBg = Instance.new("Frame", TabContent)
            SliderBg.Size = UDim2.new(1, -10, 0, 50)
            SliderBg.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", SliderBg).Color = Color3.fromRGB(45, 45, 45)

            local Label = Instance.new("TextLabel", SliderBg)
            Label.Size = UDim2.new(1, -20, 0, 20)
            Label.Position = UDim2.new(0, 15, 0, 6)
            Label.BackgroundTransparency = 1
            Label.Text = opts.Name or "Slider"
            Label.TextColor3 = Color3.fromRGB(220, 220, 220)
            Label.Font = Enum.Font.GothamSemibold
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local ValLabel = Instance.new("TextLabel", SliderBg)
            ValLabel.Size = UDim2.new(0, 50, 0, 20)
            ValLabel.Position = UDim2.new(1, -65, 0, 6)
            ValLabel.BackgroundTransparency = 1
            ValLabel.Text = tostring(default)
            ValLabel.TextColor3 = ThemeColor
            ValLabel.Font = Enum.Font.GothamBold
            ValLabel.TextSize = 13
            ValLabel.TextXAlignment = Enum.TextXAlignment.Right

            local Track = Instance.new("Frame", SliderBg)
            Track.Size = UDim2.new(1, -30, 0, 4)
            Track.Position = UDim2.new(0, 15, 0, 34)
            Track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame", Track)
            Fill.Size = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), 0, 1, 0)
            Fill.BackgroundColor3 = ThemeColor
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            table.insert(ThemeUpdateFunctions, function()
                TweenService:Create(Fill, TweenInfo.new(0.3), {BackgroundColor3 = ThemeColor}):Play()
                TweenService:Create(ValLabel, TweenInfo.new(0.3), {TextColor3 = ThemeColor}):Play()
            end)

            local dragging = false
            local function updateSlider(input)
                local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local val = min + ((max - min) * pos)
                val = math.floor(val / inc + 0.5) * inc
                
                TweenService:Create(Fill, TweenInfo.new(0.15), {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}):Play()
                ValLabel.Text = tostring(val)
                ConfigData[opts.Name] = val
                SaveConfig()
                if opts.Callback then opts.Callback(val) end
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; updateSlider(input) end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
            end)

            if opts.Callback then opts.Callback(default) end
        end

        function Elements:AddDropdown(opts)
            local default = ConfigData[opts.Name] ~= nil and ConfigData[opts.Name] or (opts.Default or opts.Options[1] or "None")
            
            local DropBg = Instance.new("Frame", TabContent)
            DropBg.Size = UDim2.new(1, -10, 0, 36)
            DropBg.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            DropBg.ClipsDescendants = true
            Instance.new("UICorner", DropBg).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", DropBg).Color = Color3.fromRGB(45, 45, 45)

            local DropBtn = Instance.new("TextButton", DropBg)
            DropBtn.Size = UDim2.new(1, 0, 0, 36)
            DropBtn.BackgroundTransparency = 1
            DropBtn.Text = "   " .. (opts.Name or "Dropdown") .. " : " .. default
            DropBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
            DropBtn.Font = Enum.Font.GothamSemibold
            DropBtn.TextSize = 13
            DropBtn.TextXAlignment = Enum.TextXAlignment.Left

            local DropLayout = Instance.new("UIListLayout", DropBg)
            DropLayout.Padding = UDim.new(0, 2)
            DropLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

            local OffsetFrame = Instance.new("Frame", DropBg)
            OffsetFrame.Size = UDim2.new(1, 0, 0, 34)
            OffsetFrame.BackgroundTransparency = 1
            OffsetFrame.LayoutOrder = -1

            local expanded = false
            DropBtn.MouseButton1Click:Connect(function()
                expanded = not expanded
                local targetSize = expanded and UDim2.new(1, -10, 0, 36 + (#opts.Options * 25)) or UDim2.new(1, -10, 0, 36)
                TweenService:Create(DropBg, TweenInfo.new(0.2), {Size = targetSize}):Play()
            end)

            for _, option in ipairs(opts.Options) do
                local OptBtn = Instance.new("TextButton", DropBg)
                OptBtn.Size = UDim2.new(1, -10, 0, 25)
                OptBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                OptBtn.Text = option
                OptBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
                OptBtn.Font = Enum.Font.Gotham
                OptBtn.TextSize = 12
                Instance.new("UICorner", OptBtn).CornerRadius = UDim.new(0, 4)

                OptBtn.MouseButton1Click:Connect(function()
                    DropBtn.Text = "   " .. (opts.Name or "Dropdown") .. " : " .. option
                    expanded = false
                    TweenService:Create(DropBg, TweenInfo.new(0.2), {Size = UDim2.new(1, -10, 0, 36)}):Play()
                    ConfigData[opts.Name] = option
                    SaveConfig()
                    if opts.Callback then opts.Callback(option) end
                end)
            end
            if opts.Callback then opts.Callback(default) end
        end

        function Elements:AddKeybind(opts)
            local currentKey = opts.Default or Enum.KeyCode.E
            local binding = false

            local BindBtn = Instance.new("TextButton", TabContent)
            BindBtn.Size = UDim2.new(1, -10, 0, 36)
            BindBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            BindBtn.Text = "   " .. (opts.Name or "Keybind")
            BindBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
            BindBtn.Font = Enum.Font.GothamSemibold
            BindBtn.TextSize = 13
            BindBtn.TextXAlignment = Enum.TextXAlignment.Left
            BindBtn.AutoButtonColor = false
            Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", BindBtn).Color = Color3.fromRGB(45, 45, 45)

            local KeyLabel = Instance.new("TextLabel", BindBtn)
            KeyLabel.Size = UDim2.new(0, 60, 0, 22)
            KeyLabel.Position = UDim2.new(1, -70, 0.5, -11)
            KeyLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            KeyLabel.Text = currentKey.Name
            KeyLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            KeyLabel.Font = Enum.Font.GothamBold
            KeyLabel.TextSize = 12
            Instance.new("UICorner", KeyLabel).CornerRadius = UDim.new(0, 4)

            BindBtn.MouseButton1Click:Connect(function()
                binding = true
                KeyLabel.Text = "..."
                TweenService:Create(KeyLabel, TweenInfo.new(0.2), {BackgroundColor3 = ThemeColor}):Play()
            end)

            UserInputService.InputBegan:Connect(function(input)
                if binding and input.UserInputType == Enum.UserInputType.Keyboard then
                    currentKey = input.KeyCode
                    KeyLabel.Text = currentKey.Name
                    TweenService:Create(KeyLabel, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
                    binding = false
                elseif not binding and input.KeyCode == currentKey then
                    if opts.Callback then opts.Callback(currentKey) end
                end
            end)
            
            table.insert(ThemeUpdateFunctions, function()
                if binding then TweenService:Create(KeyLabel, TweenInfo.new(0.3), {BackgroundColor3 = ThemeColor}):Play() end
            end)
        end

        function Elements:AddColorPicker(opts)
            local DefaultColor = opts.Default or Color3.fromRGB(255, 255, 255)
            local CurrentColor = DefaultColor
            local h, s, v = CurrentColor:ToHSV()

            local CPBg = Instance.new("Frame", TabContent)
            CPBg.Size = UDim2.new(1, -10, 0, 36)
            CPBg.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            CPBg.ClipsDescendants = true
            Instance.new("UICorner", CPBg).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", CPBg).Color = Color3.fromRGB(45, 45, 45)

            local TopBtn = Instance.new("TextButton", CPBg)
            TopBtn.Size = UDim2.new(1, 0, 0, 36)
            TopBtn.BackgroundTransparency = 1
            TopBtn.Text = ""

            local Title = Instance.new("TextLabel", TopBtn)
            Title.Size = UDim2.new(1, -20, 1, 0)
            Title.Position = UDim2.new(0, 15, 0, 0)
            Title.BackgroundTransparency = 1
            Title.Text = opts.Name or "Color Picker"
            Title.TextColor3 = Color3.fromRGB(220, 220, 220)
            Title.Font = Enum.Font.GothamSemibold
            Title.TextSize = 13
            Title.TextXAlignment = Enum.TextXAlignment.Left

            local ColorDisplay = Instance.new("Frame", TopBtn)
            ColorDisplay.Size = UDim2.new(0, 24, 0, 24)
            ColorDisplay.Position = UDim2.new(1, -34, 0.5, -12)
            ColorDisplay.BackgroundColor3 = CurrentColor
            Instance.new("UICorner", ColorDisplay).CornerRadius = UDim.new(0, 4)

            local Expanded = false
            local ContentArea = Instance.new("Frame", CPBg)
            ContentArea.Size = UDim2.new(1, 0, 0, 160)
            ContentArea.Position = UDim2.new(0, 0, 0, 36)
            ContentArea.BackgroundTransparency = 1

            local ColorWheel = Instance.new("ImageLabel", ContentArea)
            ColorWheel.Size = UDim2.new(0, 100, 0, 100)
            ColorWheel.Position = UDim2.new(0, 15, 0, 10)
            ColorWheel.Image = "rbxassetid://6020299385" 
            ColorWheel.BackgroundTransparency = 1

            local Selector = Instance.new("Frame", ColorWheel)
            Selector.Size = UDim2.new(0, 8, 0, 8)
            Selector.AnchorPoint = Vector2.new(0.5, 0.5)
            Selector.Position = UDim2.new(0.5, 0, 0.5, 0)
            Selector.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", Selector).CornerRadius = UDim.new(1, 0)
            Instance.new("UIStroke", Selector).Color = Color3.fromRGB(0, 0, 0)

            local DarknessBg = Instance.new("Frame", ContentArea)
            DarknessBg.Size = UDim2.new(0, 15, 0, 100)
            DarknessBg.Position = UDim2.new(0, 125, 0, 10)
            DarknessBg.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", DarknessBg).CornerRadius = UDim.new(1, 0)
            local UIGradient = Instance.new("UIGradient", DarknessBg)
            UIGradient.Rotation = 90
            UIGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))}

            local HexBox = Instance.new("TextBox", ContentArea)
            HexBox.Size = UDim2.new(0, 100, 0, 25)
            HexBox.Position = UDim2.new(0, 160, 0, 10)
            HexBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            HexBox.Text = "#" .. CurrentColor:ToHex()
            HexBox.TextColor3 = Color3.fromRGB(200, 200, 200)
            HexBox.Font = Enum.Font.GothamMedium
            HexBox.TextSize = 12
            Instance.new("UICorner", HexBox).CornerRadius = UDim.new(0, 4)
            Instance.new("UIStroke", HexBox).Color = Color3.fromRGB(45, 45, 45)

            TopBtn.MouseButton1Click:Connect(function()
                Expanded = not Expanded
                TweenService:Create(CPBg, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = Expanded and UDim2.new(1, -10, 0, 160) or UDim2.new(1, -10, 0, 36)}):Play()
            end)

            local function UpdateColor()
                CurrentColor = Color3.fromHSV(h, s, v)
                ColorDisplay.BackgroundColor3 = CurrentColor
                UIGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromHSV(h, s, 1)), ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))}
                HexBox.Text = "#" .. CurrentColor:ToHex():upper()
                if opts.Callback then opts.Callback(CurrentColor) end
            end

            local draggingWheel = false
            ColorWheel.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWheel = true end end)
            UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWheel = false end end)
            
            UserInputService.InputChanged:Connect(function(input)
                if draggingWheel and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local center = ColorWheel.AbsolutePosition + (ColorWheel.AbsoluteSize / 2)
                    local mouse = input.Position
                    local dist = (Vector2.new(mouse.X, mouse.Y) - center).Magnitude
                    local maxDist = ColorWheel.AbsoluteSize.X / 2
                    local angle = math.deg(math.atan2(mouse.Y - center.Y, mouse.X - center.X)) + 90
                    if angle < 0 then angle = angle + 360 end
                    h = angle / 360
                    s = math.clamp(dist / maxDist, 0, 1)

                    local selX = math.cos(math.rad(angle - 90)) * (s * maxDist)
                    local selY = math.sin(math.rad(angle - 90)) * (s * maxDist)
                    Selector.Position = UDim2.new(0.5, selX, 0.5, selY)
                    UpdateColor()
                end
            end)

            HexBox.FocusLost:Connect(function()
                pcall(function()
                    local newCol = Color3.fromHex(HexBox.Text)
                    h, s, v = newCol:ToHSV()
                    UpdateColor()
                end)
            end)
        end

        return Elements
    end

    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsTabAction then
            SettingsTabAction()
        else
            Nova:MakeNotification({Name = "Settings", Content = "The Settings tab is currently disabled.", Time = 3})
        end
    end)

    if options.ShowSettings then
        local SettingsTab = Window:MakeTab({Name = "Settings", Icon = "rbxassetid://7734068321", Hidden = true})
        SettingsTab:AddLabel({Text = "Hub Customization"})

        SettingsTab:AddColorPicker({
            Name = "Theme Color",
            Default = ThemeColor,
            Callback = function(color) UpdateTheme(color) end
        })
        
        SettingsTab:AddSlider({
            Name = "Hub Transparency",
            Min = 0, Max = 1, Default = 0, Increment = 0.05,
            Callback = function(val)
                MainFrame.BackgroundTransparency = val
                SidebarContainer.BackgroundTransparency = val
                TopBar.BackgroundTransparency = val
            end
        })

        SettingsTab:AddDropdown({
            Name = "UI Font",
            Options = {"Gotham", "Code", "Jura", "Roboto", "SciFi", "Arcade"},
            Default = "Gotham",
            Callback = function(fontName)
                local f = Enum.Font.Gotham
                if fontName == "Code" then f = Enum.Font.Code
                elseif fontName == "Jura" then f = Enum.Font.Jura
                elseif fontName == "Roboto" then f = Enum.Font.Roboto
                elseif fontName == "SciFi" then f = Enum.Font.SciFi 
                elseif fontName == "Arcade" then f = Enum.Font.Arcade end
                
                for _, obj in ipairs(MainFrame:GetDescendants()) do
                    if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
                        pcall(function() obj.Font = f end)
                    end
                end
            end
        })

        SettingsTab:AddToggle({
            Name = "Custom Background Image",
            Default = false,
            Callback = function(state)
                BackgroundImage.Visible = state
            end
        })
    end

    return Window
end

return Nova
