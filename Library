-- Nova UI Library V4 (The Zenith Edition)
local Nova = {}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Executor Protections
local isfolder = isfolder or function() return false end
local makefolder = makefolder or function() end
local isfile = isfile or function() return false end
local readfile = readfile or function() return "{}" end
local writefile = writefile or function() end

local function GetSafeParent()
    if gethui then return gethui() end
    local success, coreGui = pcall(function() return CoreGui end)
    if success and coreGui then return coreGui end
    return LocalPlayer:WaitForChild("PlayerGui")
end

local SafeParent = GetSafeParent()
for _, child in ipairs(SafeParent:GetChildren()) do
    if child.Name == "NovaUI_Hub" then child:Destroy() end
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "NovaUI_Hub"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = SafeParent

local ThemeColor = Color3.fromRGB(0, 170, 255)
local ThemeUpdateFunctions = {}

local function UpdateTheme(newColor)
    ThemeColor = newColor
    for _, func in ipairs(ThemeUpdateFunctions) do pcall(func) end
end

-- Configuration System
local ConfigData = {}
local ConfigOptions = {SaveConfig = false, Folder = "NovaConfigs"}

local function SaveConfig()
    if ConfigOptions.SaveConfig then
        if not isfolder(ConfigOptions.Folder) then makefolder(ConfigOptions.Folder) end
        writefile(ConfigOptions.Folder .. "/config.json", HttpService:JSONEncode(ConfigData))
    end
end

local function LoadConfig()
    if ConfigOptions.SaveConfig and isfile(ConfigOptions.Folder .. "/config.json") then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigOptions.Folder .. "/config.json")) end)
        if success and type(data) == "table" then ConfigData = data end
    end
end

-- Main UI Function
function Nova:MakeWindow(options)
    local WindowTitle = options.Title or "Nova UI Hub"
    ConfigOptions.SaveConfig = options.SaveConfig or false
    ConfigOptions.Folder = options.ConfigFolder or "NovaConfigs"
    LoadConfig()
    
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 600, 0, 400) -- Made slightly larger for advanced UI
    MainFrame.Position = UDim2.new(0.5, -300, 0.5, -200)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(45, 45, 45)

    local uiScale = Instance.new("UIScale", MainFrame)
    uiScale.Scale = 0.8
    TweenService:Create(uiScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()

    -- TopBar & MacOS Controls
    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    TopBar.BorderSizePixel = 0
    Instance.new("UICorner", TopBar).CornerRadius = UDim.new(0, 8)
    
    local TopBarHider = Instance.new("Frame", TopBar)
    TopBarHider.Size = UDim2.new(1, 0, 0, 5)
    TopBarHider.Position = UDim2.new(0, 0, 1, -5)
    TopBarHider.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    TopBarHider.BorderSizePixel = 0

    local TitleLabel = Instance.new("TextLabel", TopBar)
    TitleLabel.Size = UDim2.new(1, -100, 1, 0)
    TitleLabel.Position = UDim2.new(0, 70, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = WindowTitle
    TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 13
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    local MacControls = Instance.new("Frame", TopBar)
    MacControls.Size = UDim2.new(0, 60, 1, 0)
    MacControls.Position = UDim2.new(0, 10, 0, 0)
    MacControls.BackgroundTransparency = 1

    local function CreateMacButton(name, color, posOffset, hoverColor)
        local btn = Instance.new("TextButton", MacControls)
        btn.Size = UDim2.new(0, 12, 0, 12)
        btn.Position = UDim2.new(0, posOffset, 0.5, -6)
        btn.BackgroundColor3 = color
        btn.Text = ""
        Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
        btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = hoverColor}):Play() end)
        btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color}):Play() end)
        return btn
    end

    local CloseBtn = CreateMacButton("Close", Color3.fromRGB(255, 95, 86), 0, Color3.fromRGB(255, 130, 120))
    local MinBtn = CreateMacButton("Minimize", Color3.fromRGB(255, 189, 46), 20, Color3.fromRGB(255, 210, 90))
    CreateMacButton("Maximize", Color3.fromRGB(39, 201, 63), 40, Color3.fromRGB(80, 220, 100))

    CloseBtn.MouseButton1Click:Connect(function()
        local tween = TweenService:Create(uiScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0})
        tween:Play(); tween.Completed:Wait(); ScreenGui:Destroy()
    end)

    local minimized = false
    MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        local newSize = minimized and UDim2.new(0, 600, 0, 35) or UDim2.new(0, 600, 0, 400)
        TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = newSize}):Play()
    end)

    local dragging, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = MainFrame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Layout
    local SidebarContainer = Instance.new("Frame", MainFrame)
    SidebarContainer.Size = UDim2.new(0, 150, 1, -35)
    SidebarContainer.Position = UDim2.new(0, 0, 0, 35)
    SidebarContainer.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    SidebarContainer.BorderSizePixel = 0

    local Sidebar = Instance.new("ScrollingFrame", SidebarContainer)
    Sidebar.Size = UDim2.new(1, -10, 1, -60) -- Leaves room for Profile
    Sidebar.Position = UDim2.new(0, 5, 0, 5)
    Sidebar.BackgroundTransparency = 1
    Sidebar.ScrollBarThickness = 0
    local SidebarLayout = Instance.new("UIListLayout", Sidebar)
    SidebarLayout.Padding = UDim.new(0, 5)

    -- [V4 FEATURE]: USER PROFILE & SETTINGS GEAR
    local ProfileFrame = Instance.new("Frame", SidebarContainer)
    ProfileFrame.Size = UDim2.new(1, 0, 0, 50)
    ProfileFrame.Position = UDim2.new(0, 0, 1, -50)
    ProfileFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
    ProfileFrame.BorderSizePixel = 0
    
    local ProfileStroke = Instance.new("Frame", ProfileFrame)
    ProfileStroke.Size = UDim2.new(1, 0, 0, 1)
    ProfileStroke.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    ProfileStroke.BorderSizePixel = 0

    local Avatar = Instance.new("ImageLabel", ProfileFrame)
    Avatar.Size = UDim2.new(0, 30, 0, 30)
    Avatar.Position = UDim2.new(0, 10, 0.5, -15)
    Avatar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1, 0)
    -- Fetch Avatar
    task.spawn(function()
        local content, isReady = Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        if isReady then Avatar.Image = content end
    end)

    local Username = Instance.new("TextLabel", ProfileFrame)
    Username.Size = UDim2.new(1, -75, 0, 15)
    Username.Position = UDim2.new(0, 48, 0.5, -12)
    Username.BackgroundTransparency = 1
    Username.Text = LocalPlayer.DisplayName
    Username.TextColor3 = Color3.fromRGB(255, 255, 255)
    Username.Font = Enum.Font.GothamBold
    Username.TextSize = 12
    Username.TextXAlignment = Enum.TextXAlignment.Left

    local SubName = Instance.new("TextLabel", ProfileFrame)
    SubName.Size = UDim2.new(1, -75, 0, 15)
    SubName.Position = UDim2.new(0, 48, 0.5, 2)
    SubName.BackgroundTransparency = 1
    SubName.Text = "@" .. LocalPlayer.Name
    SubName.TextColor3 = Color3.fromRGB(120, 120, 120)
    SubName.Font = Enum.Font.Gotham
    SubName.TextSize = 10
    SubName.TextXAlignment = Enum.TextXAlignment.Left

    local SettingsBtn = Instance.new("ImageButton", ProfileFrame)
    SettingsBtn.Size = UDim2.new(0, 18, 0, 18)
    SettingsBtn.Position = UDim2.new(1, -25, 0.5, -9)
    SettingsBtn.BackgroundTransparency = 1
    SettingsBtn.Image = "rbxassetid://7734068321" -- Gear icon
    SettingsBtn.ImageColor3 = Color3.fromRGB(150, 150, 150)
    
    SettingsBtn.MouseEnter:Connect(function() TweenService:Create(SettingsBtn, TweenInfo.new(0.2), {ImageColor3 = ThemeColor, Rotation = 45}):Play() end)
    SettingsBtn.MouseLeave:Connect(function() TweenService:Create(SettingsBtn, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(150, 150, 150), Rotation = 0}):Play() end)

    local ContentContainer = Instance.new("Frame", MainFrame)
    ContentContainer.Size = UDim2.new(1, -150, 1, -35)
    ContentContainer.Position = UDim2.new(0, 150, 0, 35)
    ContentContainer.BackgroundTransparency = 1

    local Window = {}
    local Tabs = {}
    local CurrentActiveTab = nil
    local SettingsTabAction = nil

    function Window:MakeTab(tabOpts)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(1, 0, 0, 32)
        TabBtn.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
        TabBtn.Text = ""
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local IconLabel = Instance.new("ImageLabel", TabBtn)
        IconLabel.Size = UDim2.new(0, 16, 0, 16)
        IconLabel.Position = UDim2.new(0, 10, 0.5, -8)
        IconLabel.BackgroundTransparency = 1
        IconLabel.Image = tabOpts.Icon or "rbxassetid://4483362458"
        IconLabel.ImageColor3 = Color3.fromRGB(150, 150, 150)
        
        local TextLbl = Instance.new("TextLabel", TabBtn)
        TextLbl.Size = UDim2.new(1, -35, 1, 0)
        TextLbl.Position = UDim2.new(0, 35, 0, 0)
        TextLbl.BackgroundTransparency = 1
        TextLbl.Text = tabOpts.Name or "Tab"
        TextLbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        TextLbl.Font = Enum.Font.GothamSemibold
        TextLbl.TextSize = 13
        TextLbl.TextXAlignment = Enum.TextXAlignment.Left

        local TabContent = Instance.new("ScrollingFrame", ContentContainer)
        TabContent.Size = UDim2.new(1, -10, 1, -10)
        TabContent.Position = UDim2.new(0, 5, 0, 5)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 2
        TabContent.Visible = false
        local ContentLayout = Instance.new("UIListLayout", TabContent)
        ContentLayout.Padding = UDim.new(0, 8)

        table.insert(Tabs, {Btn = TabBtn, Text = TextLbl, Icon = IconLabel, Content = TabContent})

        local function ActivateTab()
            CurrentActiveTab = TabBtn
            for _, t in pairs(Tabs) do
                TweenService:Create(t.Btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(18, 18, 18)}):Play()
                TweenService:Create(t.Text, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
                TweenService:Create(t.Icon, TweenInfo.new(0.3), {ImageColor3 = Color3.fromRGB(150, 150, 150)}):Play()
                t.Content.Visible = false
            end
            TweenService:Create(TabBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
            TweenService:Create(TextLbl, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            TweenService:Create(IconLabel, TweenInfo.new(0.3), {ImageColor3 = ThemeColor}):Play()
            TabContent.Visible = true
        end

        TabBtn.MouseButton1Click:Connect(ActivateTab)
        if #Tabs == 1 then ActivateTab() end

        -- Link Settings Gear to this tab if it's named "Settings"
        if tabOpts.Name == "Settings" then SettingsTabAction = ActivateTab end

        local Elements = {}

        -- Universal Icon function for elements
        local function AddIcon(parent, iconId)
            if not iconId then return 0 end
            local Ico = Instance.new("ImageLabel", parent)
            Ico.Size = UDim2.new(0, 16, 0, 16)
            Ico.Position = UDim2.new(0, 10, 0.5, -8)
            Ico.BackgroundTransparency = 1
            Ico.Image = iconId
            Ico.ImageColor3 = Color3.fromRGB(220, 220, 220)
            return 25
        end

        function Elements:AddButton(opts)
            local Btn = Instance.new("TextButton", TabContent)
            Btn.Size = UDim2.new(1, -10, 0, 36)
            Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Btn.Text = ""
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", Btn).Color = Color3.fromRGB(45, 45, 45)

            local offset = AddIcon(Btn, opts.Icon)
            local Title = Instance.new("TextLabel", Btn)
            Title.Size = UDim2.new(1, -(15 + offset), 1, 0)
            Title.Position = UDim2.new(0, 15 + offset, 0, 0)
            Title.BackgroundTransparency = 1
            Title.Text = opts.Name or "Button"
            Title.TextColor3 = Color3.fromRGB(220, 220, 220)
            Title.Font = Enum.Font.GothamSemibold
            Title.TextSize = 13
            Title.TextXAlignment = Enum.TextXAlignment.Left

            Btn.MouseEnter:Connect(function() TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}):Play() end)
            Btn.MouseLeave:Connect(function() TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play() end)
            Btn.MouseButton1Click:Connect(function()
                TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = ThemeColor}):Play()
                task.wait(0.1)
                TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}):Play()
                if opts.Callback then opts.Callback() end
            end)
        end

        function Elements:AddToggle(opts)
            local state = ConfigData[opts.Name] ~= nil and ConfigData[opts.Name] or (opts.Default or false)
            
            local Tog = Instance.new("TextButton", TabContent)
            Tog.Size = UDim2.new(1, -10, 0, 36)
            Tog.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Tog.Text = ""
            Instance.new("UICorner", Tog).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", Tog).Color = Color3.fromRGB(45, 45, 45)

            local offset = AddIcon(Tog, opts.Icon)
            local Title = Instance.new("TextLabel", Tog)
            Title.Size = UDim2.new(1, -(15 + offset), 1, 0)
            Title.Position = UDim2.new(0, 15 + offset, 0, 0)
            Title.BackgroundTransparency = 1
            Title.Text = opts.Name or "Toggle"
            Title.TextColor3 = Color3.fromRGB(220, 220, 220)
            Title.Font = Enum.Font.GothamSemibold
            Title.TextSize = 13
            Title.TextXAlignment = Enum.TextXAlignment.Left

            local IndicatorBg = Instance.new("Frame", Tog)
            IndicatorBg.Size = UDim2.new(0, 36, 0, 18)
            IndicatorBg.Position = UDim2.new(1, -46, 0.5, -9)
            IndicatorBg.BackgroundColor3 = state and ThemeColor or Color3.fromRGB(40, 40, 40)
            Instance.new("UICorner", IndicatorBg).CornerRadius = UDim.new(1, 0)

            local Circle = Instance.new("Frame", IndicatorBg)
            Circle.Size = UDim2.new(0, 14, 0, 14)
            Circle.Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            Tog.MouseButton1Click:Connect(function()
                state = not state
                ConfigData[opts.Name] = state
                SaveConfig()
                local targetPos = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
                local targetColor = state and ThemeColor or Color3.fromRGB(40, 40, 40)
                TweenService:Create(Circle, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetPos}):Play()
                TweenService:Create(IndicatorBg, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
                if opts.Callback then opts.Callback(state) end
            end)

            table.insert(ThemeUpdateFunctions, function()
                if state then TweenService:Create(IndicatorBg, TweenInfo.new(0.3), {BackgroundColor3 = ThemeColor}):Play() end
            end)
            if state and opts.Callback then opts.Callback(state) end
        end

        --[V4 FEATURE]: ADVANCED COLOR PICKER
        function Elements:AddColorPicker(opts)
            local DefaultColor = opts.Default or Color3.fromRGB(255, 255, 255)
            local CurrentColor = DefaultColor
            local h, s, v = CurrentColor:ToHSV()

            local CPBg = Instance.new("Frame", TabContent)
            CPBg.Size = UDim2.new(1, -10, 0, 36)
            CPBg.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            CPBg.ClipsDescendants = true
            Instance.new("UICorner", CPBg).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", CPBg).Color = Color3.fromRGB(45, 45, 45)

            local TopBtn = Instance.new("TextButton", CPBg)
            TopBtn.Size = UDim2.new(1, 0, 0, 36)
            TopBtn.BackgroundTransparency = 1
            TopBtn.Text = ""

            local Title = Instance.new("TextLabel", TopBtn)
            Title.Size = UDim2.new(1, -20, 1, 0)
            Title.Position = UDim2.new(0, 15, 0, 0)
            Title.BackgroundTransparency = 1
            Title.Text = opts.Name or "Color Picker"
            Title.TextColor3 = Color3.fromRGB(220, 220, 220)
            Title.Font = Enum.Font.GothamSemibold
            Title.TextSize = 13
            Title.TextXAlignment = Enum.TextXAlignment.Left

            local ColorDisplay = Instance.new("Frame", TopBtn)
            ColorDisplay.Size = UDim2.new(0, 24, 0, 24)
            ColorDisplay.Position = UDim2.new(1, -34, 0.5, -12)
            ColorDisplay.BackgroundColor3 = CurrentColor
            Instance.new("UICorner", ColorDisplay).CornerRadius = UDim.new(0, 4)

            local Expanded = false
            -- Color Picker Content Area
            local ContentArea = Instance.new("Frame", CPBg)
            ContentArea.Size = UDim2.new(1, 0, 0, 160)
            ContentArea.Position = UDim2.new(0, 0, 0, 36)
            ContentArea.BackgroundTransparency = 1

            -- Color Wheel (Hue & Saturation)
            local ColorWheel = Instance.new("ImageLabel", ContentArea)
            ColorWheel.Size = UDim2.new(0, 100, 0, 100)
            ColorWheel.Position = UDim2.new(0, 15, 0, 10)
            ColorWheel.Image = "rbxassetid://6020299385" -- Circle Spectrum
            ColorWheel.BackgroundTransparency = 1

            local Selector = Instance.new("Frame", ColorWheel)
            Selector.Size = UDim2.new(0, 8, 0, 8)
            Selector.AnchorPoint = Vector2.new(0.5, 0.5)
            Selector.Position = UDim2.new(0.5, 0, 0.5, 0)
            Selector.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", Selector).CornerRadius = UDim.new(1, 0)
            Instance.new("UIStroke", Selector).Color = Color3.fromRGB(0, 0, 0)

            -- Darkness Slider
            local DarknessBg = Instance.new("Frame", ContentArea)
            DarknessBg.Size = UDim2.new(0, 15, 0, 100)
            DarknessBg.Position = UDim2.new(0, 125, 0, 10)
            DarknessBg.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", DarknessBg).CornerRadius = UDim.new(1, 0)
            local UIGradient = Instance.new("UIGradient", DarknessBg)
            UIGradient.Rotation = 90
            UIGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))}

            local DarkSelector = Instance.new("Frame", DarknessBg)
            DarkSelector.Size = UDim2.new(1, 4, 0, 4)
            DarkSelector.Position = UDim2.new(0, -2, 0, -2)
            DarkSelector.BackgroundColor3 = Color3.fromRGB(255, 255, 255)

            -- HEX & RGB Inputs
            local HexBox = Instance.new("TextBox", ContentArea)
            HexBox.Size = UDim2.new(0, 100, 0, 25)
            HexBox.Position = UDim2.new(0, 160, 0, 10)
            HexBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            HexBox.Text = "#" .. CurrentColor:ToHex()
            HexBox.TextColor3 = Color3.fromRGB(200, 200, 200)
            HexBox.Font = Enum.Font.GothamMedium
            HexBox.TextSize = 12
            Instance.new("UICorner", HexBox).CornerRadius = UDim.new(0, 4)
            Instance.new("UIStroke", HexBox).Color = Color3.fromRGB(45, 45, 45)

            TopBtn.MouseButton1Click:Connect(function()
                Expanded = not Expanded
                TweenService:Create(CPBg, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = Expanded and UDim2.new(1, -10, 0, 160) or UDim2.new(1, -10, 0, 36)}):Play()
            end)

            local function UpdateColor()
                CurrentColor = Color3.fromHSV(h, s, v)
                ColorDisplay.BackgroundColor3 = CurrentColor
                UIGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromHSV(h, s, 1)), ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))}
                HexBox.Text = "#" .. CurrentColor:ToHex():upper()
                if opts.Callback then opts.Callback(CurrentColor) end
            end

            -- Circle Math
            local draggingWheel = false
            ColorWheel.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWheel = true end end)
            UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWheel = false end end)
            
            UserInputService.InputChanged:Connect(function(input)
                if draggingWheel and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local center = ColorWheel.AbsolutePosition + (ColorWheel.AbsoluteSize / 2)
                    local mouse = input.Position
                    local dist = (Vector2.new(mouse.X, mouse.Y) - center).Magnitude
                    local maxDist = ColorWheel.AbsoluteSize.X / 2
                    
                    local angle = math.deg(math.atan2(mouse.Y - center.Y, mouse.X - center.X)) + 90
                    if angle < 0 then angle = angle + 360 end
                    h = angle / 360
                    s = math.clamp(dist / maxDist, 0, 1)

                    -- Move selector
                    local selX = math.cos(math.rad(angle - 90)) * (s * maxDist)
                    local selY = math.sin(math.rad(angle - 90)) * (s * maxDist)
                    Selector.Position = UDim2.new(0.5, selX, 0.5, selY)
                    UpdateColor()
                end
            end)

            -- Hex Input logic
            HexBox.FocusLost:Connect(function()
                pcall(function()
                    local newCol = Color3.fromHex(HexBox.Text)
                    h, s, v = newCol:ToHSV()
                    UpdateColor()
                end)
            end)
        end

        return Elements
    end

    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsTabAction then SettingsTabAction() end
    end)

    if options.ShowSettings then
        local SettingsTab = Window:MakeTab({Name = "Settings", Icon = "rbxassetid://7734068321"})
        SettingsTab:AddLabel({Text = "Customization"})
        SettingsTab:AddColorPicker({
            Name = "Hub Theme Color",
            Default = ThemeColor,
            Callback = function(color) UpdateTheme(color) end
        })
    end

    return Window
end

return Nova
