    AccentBar.Position = UDim2.new(0, 0, 0, 8)
    AccentBar.BackgroundColor3 = Theme.Accent
    Instance.new("UICorner", AccentBar).CornerRadius = UDim.new(1, 0)

    local IconImg = Instance.new("ImageLabel", notifFrame)
    IconImg.Size = UDim2.new(0, 18, 0, 18)
    IconImg.Position = UDim2.new(0, 14, 0, 10)
    IconImg.BackgroundTransparency = 1
    IconImg.Image = icon
    IconImg.ImageColor3 = Theme.Accent
    IconImg.ImageTransparency = 1

    local titleLbl = Instance.new("TextLabel", notifFrame)
    titleLbl.Size = UDim2.new(1, -45, 0, 20)
    titleLbl.Position = UDim2.new(0, 38, 0, 7)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Theme.Accent
    titleLbl.Font = Theme.FontBold
    titleLbl.TextSize = 13
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTransparency = 1

    local descLbl = Instance.new("TextLabel", notifFrame)
    descLbl.Size = UDim2.new(1, -20, 0, 32)
    descLbl.Position = UDim2.new(0, 14, 0, 30)
    descLbl.BackgroundTransparency = 1
    descLbl.Text = content
    descLbl.TextColor3 = Color3.fromRGB(190, 190, 190)
    descLbl.Font = Theme.Font
    descLbl.TextSize = 12
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.TextWrapped = true
    descLbl.TextTransparency = 1
    notifFrame.Parent = NotifContainer

    TweenService:Create(notifFrame, TweenInfo.new(0.45, Enum.EasingStyle.Quint), {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0.1}):Play()
    TweenService:Create(titleLbl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    TweenService:Create(descLbl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    TweenService:Create(IconImg, TweenInfo.new(0.4), {ImageTransparency = 0}):Play()

    task.spawn(function()
        task.wait(time)
        TweenService:Create(titleLbl, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(descLbl, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(IconImg, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
        local fadeOut = TweenService:Create(notifFrame, TweenInfo.new(0.45, Enum.EasingStyle.Quint), {Position = UDim2.new(1, 50, 0, 0), BackgroundTransparency = 1})
        fadeOut:Play(); fadeOut.Completed:Wait(); notifFrame:Destroy()
    end)
end

