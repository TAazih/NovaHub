local function ResolveIcon(iconStr)
    if not iconStr or iconStr == "" then return "rbxassetid://4483362458" end
    if iconStr:sub(1, 7) == "lucide:" then
        local name = iconStr:sub(8)
        return LucideMap[name] or "rbxassetid://4483362458"
    end
    return iconStr
end

