-- ============================================================
-- CONFIGURATION SYSTEM
-- ============================================================
local ConfigData = {}
local ConfigOptions = {SaveConfig = false, Folder = "NovaConfigs"}

local function SaveConfig()
    if ConfigOptions.SaveConfig then
        if not isfolder(ConfigOptions.Folder) then makefolder(ConfigOptions.Folder) end
        writefile(ConfigOptions.Folder .. "/config.json", HttpService:JSONEncode(ConfigData))
    end
end

local function LoadConfig()
    if ConfigOptions.SaveConfig and isfile(ConfigOptions.Folder .. "/config.json") then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigOptions.Folder .. "/config.json")) end)
        if success and type(data) == "table" then ConfigData = data end
    end
end

