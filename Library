local Theme = {
    Accent       = Color3.fromRGB(0, 170, 255),
    Background   = Color3.fromRGB(15, 15, 15),
    Surface      = Color3.fromRGB(25, 25, 25),
    Sidebar      = Color3.fromRGB(18, 18, 18),
    TopBar       = Color3.fromRGB(20, 20, 20),
    Border       = Color3.fromRGB(45, 45, 45),
    TextPrimary  = Color3.fromRGB(220, 220, 220),
    TextMuted    = Color3.fromRGB(150, 150, 150),
    Transparency = 0,   -- 0 = opaque, 0.5 = semi, 1 = fully transparent
    Font         = Enum.Font.GothamSemibold,
    FontBold     = Enum.Font.GothamBold,
    BGImage      = "",  -- rbxassetid or URL
    BlurAmount   = 0,
}

local ThemeListeners = {}  -- {element, property, valueFunc}

local function RegisterTheme(element, property, valueFunc)
    table.insert(ThemeListeners, {e = element, p = property, f = valueFunc})
end

local function ApplyTheme()
    for _, entry in ipairs(ThemeListeners) do
        local ok, val = pcall(entry.f)
        if ok then
            pcall(function()
                TweenService:Create(entry.e, TweenInfo.new(0.3), {[entry.p] = val}):Play()
            end)
        end
    end
end

local function SetThemeValue(key, value)
    Theme[key] = value
    ApplyTheme()
end

