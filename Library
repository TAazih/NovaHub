                if opts.Callback then opts.Callback(state) end
            end

            Tog.MouseButton1Click:Connect(function() UpdateState(not state) end)

            table.insert(ThemeUpdateFunctions, function()
                if state then TweenService:Create(IndicatorBg, TweenInfo.new(0.3), {BackgroundColor3 = ThemeColor}):Play() end
            end)

            if opts.Keybind then
                local currentKey = ConfigData[opts.Name.."_Keybind"] and Enum.KeyCode[ConfigData[opts.Name.."_Keybind"]] or opts.Keybind
                local binding = false
                
                local BindBtn = Instance.new("TextButton", Tog)
