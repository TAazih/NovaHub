            local ValGrad = Instance.new("UIGradient", ValBar)
            ValGrad.Rotation = 90
            ValGrad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
            }

            local ValKnob = Instance.new("Frame", ValBar)
            ValKnob.Size = UDim2.new(0, 14, 0, 6)
            ValKnob.AnchorPoint = Vector2.new(0.5, 0.5)
            ValKnob.Position = UDim2.new(0.5, 0, 1 - v, 0)
            ValKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", ValKnob).CornerRadius = UDim.new(1, 0)
            local VK_Stroke = Instance.new("UIStroke", ValKnob)
            VK_Stroke.Color = Color3.fromRGB(0, 0, 0)
            VK_Stroke.Thickness = 1

            local HexBox = Instance.new("TextBox", ContentArea)
            HexBox.Size = UDim2.new(0, 100, 0, 28)
            HexBox.Position = UDim2.new(0, 160, 0, 12)
            HexBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            HexBox.Text = "#" .. CurrentColor:ToHex():upper()
            HexBox.TextColor3 = Color3.fromRGB(200, 200, 200)
            HexBox.Font = Theme.Font
            HexBox.TextSize = 12
            HexBox.PlaceholderText = "#RRGGBB"
            Instance.new("UICorner", HexBox).CornerRadius = UDim.new(0, 5)
            Instance.new("UIStroke", HexBox).Color = Theme.Border
            RegisterTheme(HexBox, "Font", function() return Theme.Font end)

            local function UpdateColor()
                CurrentColor = Color3.fromHSV(h, s, v)
                ColorPreview.BackgroundColor3 = CurrentColor
                ValGrad.Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromHSV(h, s, 1)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
                }
                HexBox.Text = "#" .. CurrentColor:ToHex():upper()
                if opts.Callback then opts.Callback(CurrentColor) end
            end

            TopBtn.MouseButton1Click:Connect(function()
                Expanded = not Expanded
                TweenService:Create(CPBg, TweenInfo.new(0.3, Enum.EasingStyle.Quint),
                    {Size = Expanded and UDim2.new(1, -8, 0, ExpandedH) or UDim2.new(1, -8, 0, 38)}):Play()
            end)

            -- Wheel drag
            local draggingWheel = false
            ColorWheel.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWheel = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingWheel = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if draggingWheel and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local center  = ColorWheel.AbsolutePosition + (ColorWheel.AbsoluteSize / 2)
                    local mpos    = Vector2.new(input.Position.X, input.Position.Y)
                    local dist    = (mpos - center).Magnitude
                    local maxDist = ColorWheel.AbsoluteSize.X / 2
                    local angle   = math.deg(math.atan2(input.Position.Y - center.Y, input.Position.X - center.X)) + 90
                    if angle < 0 then angle += 360 end
                    h = angle / 360
                    s = math.clamp(dist / maxDist, 0, 1)
                    local selX = math.cos(math.rad(angle - 90)) * (s * maxDist)
                    local selY = math.sin(math.rad(angle - 90)) * (s * maxDist)
                    WheelSelector.Position = UDim2.new(0.5, selX, 0.5, selY)
                    UpdateColor()
                end
            end)

            -- Val bar drag
            local draggingVal = false
            ValBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingVal = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingVal = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if draggingVal and input.UserInputType == Enum.UserInputType.MouseMovement then
                    v = math.clamp(1 - ((input.Position.Y - ValBar.AbsolutePosition.Y) / ValBar.AbsoluteSize.Y), 0, 1)
                    ValKnob.Position = UDim2.new(0.5, 0, 1 - v, 0)
                    UpdateColor()
                end
            end)

            HexBox.FocusLost:Connect(function()
                pcall(function()
                    local newCol = Color3.fromHex(HexBox.Text)
                    h, s, v = newCol:ToHSV()
                    UpdateColor()
                end)
            end)
        end

        -- ============================================================
        -- TEXT INPUT
        -- ============================================================
        function Elements:AddTextbox(opts)
            local TBBg = MakeBase(38)

            local offset = AddIconTo(TBBg, opts.Icon)
            local TBLabel = Instance.new("TextLabel", TBBg)
            TBLabel.Size = UDim2.new(0, 100, 1, 0)
            TBLabel.Position = UDim2.new(0, 14 + offset, 0, 0)
            TBLabel.BackgroundTransparency = 1
            TBLabel.Text = opts.Name or "Input"
            TBLabel.TextColor3 = Theme.TextPrimary
            TBLabel.Font = Theme.Font
            TBLabel.TextSize = 13
            TBLabel.TextXAlignment = Enum.TextXAlignment.Left
            RegisterTheme(TBLabel, "TextColor3", function() return Theme.TextPrimary end)
            RegisterTheme(TBLabel, "Font",       function() return Theme.Font end)

            local TBInput = Instance.new("TextBox", TBBg)
            TBInput.Size = UDim2.new(1, -(120 + offset), 0, 24)
            TBInput.Position = UDim2.new(0, 110 + offset, 0.5, -12)
            TBInput.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            TBInput.Text = opts.Default or ""
            TBInput.PlaceholderText = opts.Placeholder or "Type here..."
            TBInput.TextColor3 = Color3.fromRGB(220, 220, 220)
            TBInput.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
            TBInput.Font = Theme.Font
            TBInput.TextSize = 12
            TBInput.ClearTextOnFocus = opts.ClearOnFocus or false
            Instance.new("UICorner", TBInput).CornerRadius = UDim.new(0, 5)
            Instance.new("UIStroke", TBInput).Color = Theme.Border
            RegisterTheme(TBInput, "Font", function() return Theme.Font end)

            TBInput.FocusLost:Connect(function(enter)
                if opts.Callback then opts.Callback(TBInput.Text, enter) end
            end)
        end

        return Elements
    end

    -- ============================================================
    -- SETTINGS GEAR HOOKUP (FIX: always works, even before tabs added)
    -- ============================================================
    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsActivate then
            SettingsActivate()
        else
            Nova:MakeNotification({Name = "Settings", Content = "Add a 'Settings' tab to enable this.", Time = 3, Icon = "lucide:info"})
        end
    end)

    -- ============================================================
    -- BUILT-IN SETTINGS TAB (if ShowSettings = true)
    -- ============================================================
    if options.ShowSettings then
        local SettingsTab = Window:MakeTab({Name = "Settings", Icon = "lucide:settings"})

        SettingsTab:AddSection({Text = "Appearance"})

        SettingsTab:AddColorPicker({
            Name = "Accent Color",
            Default = Theme.Accent,
            Callback = function(color)
                SetThemeValue("Accent", color)
            end
        })

        SettingsTab:AddDropdown({
            Name = "Font",
            Options = {"Gotham", "Ubuntu", "SourceSans", "Oswald", "Roboto", "Arcade", "Code", "Cartoon", "Fantasy", "Bangers"},
            Default = "Gotham",
            Callback = function(val)
                local f = FontOptions[val]
                if f then
                    Theme.Font    = f.normal
                    Theme.FontBold = f.bold
                    ApplyTheme()
                end
            end
        })

        SettingsTab:AddSlider({
            Name = "Transparency",
            Min = 0, Max = 0.9, Increment = 0.05,
            Default = Theme.Transparency,
            Callback = function(val) SetThemeValue("Transparency", val) end
        })

        SettingsTab:AddSlider({
            Name = "Blur Amount",
            Min = 0, Max = 24, Increment = 1,
            Default = Theme.BlurAmount,
            Callback = function(val)
                Theme.BlurAmount = val
                TweenService:Create(BlurEffect, TweenInfo.new(0.3), {Size = val}):Play()
            end
        })

        SettingsTab:AddSection({Text = "Background"})

        SettingsTab:AddTextbox({
            Name = "BG Image ID",
            Placeholder = "rbxassetid://...",
            Callback = function(text)
                BGImage.Image = text
                SetThemeValue("BGImage", text)
            end
        })

        SettingsTab:AddSlider({
            Name = "BG Opacity",
            Min = 0, Max = 1, Increment = 0.05,
            Default = 0.7,
            Callback = function(val) BGImage.ImageTransparency = val end
        })

        SettingsTab:AddSection({Text = "Hub"})

        SettingsTab:AddButton({
            Name = "Reset Theme",
            Icon = "lucide:refresh",
            Callback = function()
                SetThemeValue("Accent",       Color3.fromRGB(0, 170, 255))
                SetThemeValue("Transparency", 0)
                SetThemeValue("BlurAmount",   0)
                Theme.Font     = Enum.Font.GothamSemibold
                Theme.FontBold = Enum.Font.GothamBold
                BGImage.Image  = ""
                BlurEffect.Size = 0
                ApplyTheme()
                Nova:MakeNotification({Name = "Reset", Content = "Theme reset to defaults.", Time = 3, Icon = "lucide:check"})
            end
        })
    end

    return Window
end

return Nova
