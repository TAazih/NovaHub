            Title.Font = Theme.Font
            Title.TextSize = 13
            Title.TextXAlignment = Enum.TextXAlignment.Left
            RegisterTheme(Title, "TextColor3", function() return Theme.TextPrimary end)
            RegisterTheme(Title, "Font",       function() return Theme.Font end)

            -- Keybind label (shows when a key is bound)
            local KeyLabel = Instance.new("TextLabel", Tog)
            KeyLabel.Size = UDim2.new(0, 0, 0, 16)
            KeyLabel.Position = UDim2.new(1, -90, 0.5, -8)
            KeyLabel.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            KeyLabel.BackgroundTransparency = boundKey and 0 or 1
            KeyLabel.Text = boundKey and "[" .. boundKey.Name .. "]" or ""
            KeyLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
            KeyLabel.Font = Theme.Font
            KeyLabel.TextSize = 10
            KeyLabel.Size = UDim2.new(0, 50, 0, 16)
            Instance.new("UICorner", KeyLabel).CornerRadius = UDim.new(0, 3)
            local KPad = Instance.new("UIPadding", KeyLabel)
            KPad.PaddingLeft  = UDim.new(0, 4)
            KPad.PaddingRight = UDim.new(0, 4)

            -- Toggle track
            local IndicatorBg = Instance.new("Frame", Tog)
            IndicatorBg.Size = UDim2.new(0, 36, 0, 18)
            IndicatorBg.Position = UDim2.new(1, -46, 0.5, -9)
            IndicatorBg.BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(40, 40, 40)
            Instance.new("UICorner", IndicatorBg).CornerRadius = UDim.new(1, 0)
            RegisterTheme(IndicatorBg, "BackgroundColor3", function()
                return state and Theme.Accent or Color3.fromRGB(40, 40, 40)
            end)

            local Circle = Instance.new("Frame", IndicatorBg)
            Circle.Size = UDim2.new(0, 14, 0, 14)
            Circle.Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            local function SetState(val)
                state = val
                ConfigData[opts.Name] = state
                SaveConfig()
                TweenService:Create(Circle, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                    {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
                TweenService:Create(IndicatorBg, TweenInfo.new(0.2),
                    {BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(40, 40, 40)}):Play()
                if opts.Callback then opts.Callback(state) end
            end

            -- Left click = toggle
            local ClickBtn = Instance.new("TextButton", Tog)
            ClickBtn.Size = UDim2.new(1, 0, 1, 0)
            ClickBtn.BackgroundTransparency = 1
            ClickBtn.Text = ""
            ClickBtn.MouseButton1Click:Connect(function() SetState(not state) end)

            -- Right click = set keybind
            local bindingKey = false
            ClickBtn.MouseButton2Click:Connect(function()
                bindingKey = true
                KeyLabel.Text = "[...]"
                KeyLabel.BackgroundTransparency = 0
                TweenService:Create(KeyLabel, TweenInfo.new(0.2), {TextColor3 = Theme.Accent}):Play()
            end)

            -- Global keybind listener
            UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if bindingKey and input.UserInputType == Enum.UserInputType.Keyboard then
                    bindingKey = false
                    if input.KeyCode == Enum.KeyCode.Escape then
                        -- Clear bind
                        boundKey = nil
                        KeyLabel.Text = ""
                        KeyLabel.BackgroundTransparency = 1
                    else
                        boundKey = input.KeyCode
                        KeyLabel.Text = "[" .. boundKey.Name .. "]"
                        KeyLabel.BackgroundTransparency = 0
                    end
                    TweenService:Create(KeyLabel, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(160, 160, 160)}):Play()
                elseif not bindingKey and boundKey and input.KeyCode == boundKey then
                    SetState(not state)
                end
            end)

            if state and opts.Callback then opts.Callback(state) end

            return {
                SetValue = function(_, v) SetState(v) end,
                GetValue = function(_) return state end,
            }
        end

